# ============================================================================
# Environment variables for the Risk Intelligence service.
#
# Copy this file to `.env` (gitignored) and fill in the values appropriate
# for your environment. For local development, the defaults baked into
# application.properties are sufficient and this file is optional.
# ============================================================================

# Database (defaults match docker-compose.yml)
# DB_URL=jdbc:postgresql://localhost:5432/esg_risk_intelligence
# DB_USERNAME=esg_user
# DB_PASSWORD=esg_dev_password

# AI service
# AI_SERVICE_BASE_URL=http://localhost:8000
# AI_SERVICE_CONNECT_TIMEOUT_MS=2000
# AI_SERVICE_READ_TIMEOUT_MS=10000

# Active Spring profile (local, staging, prod)
# SPRING_PROFILES_ACTIVE=local
